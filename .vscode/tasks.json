{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run (Release)",
			"type": "shell",
			"command": "powershell -Command \".\\Build\\Out\\Release\\CS350Framework\\*.exe\"",
			"dependsOn": ["Build (Release)"]
		},
		{
			"label": "Run (Debug)",
			"type": "shell",
			"command": "powershell -Command \".\\Build\\Out\\Debug\\CS350Framework\\*.exe\"",
			"dependsOn": ["Build (Debug)"]
		},
		{
			"label": "Build (Debug)",
			"type": "shell",
			"windows": {
				"command": "powershell -wd . -NoLogo -file \".vscode\\build-sln.ps1\""
			}
		},
		{
			"label": "Build (Release)",
			"type": "shell",
			"windows": {
				"command": "powershell -wd . -NoLogo -file \".vscode\\build-sln.ps1\" -release"
			}
		},
		{
			"label": "Developer Shell",
			"type": "shell",
			"windows": {
				"command": "powershell -wd . -NoLogo -NoExit -file \"C:/Program Files/Microsoft Visual Studio/2022/Community/Common7/Tools/Launch-VsDevShell.ps1\" -SkipAutomaticLocation"
			}
		}
	]
}
